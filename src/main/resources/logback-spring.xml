<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%X{correlationId:-no-id}] %-5level %-40logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Application code at DEBUG so balance/detail logs are visible -->
    <logger name="com.eventledger" level="DEBUG"/>

    <!-- Spring Boot internals stay at INFO to avoid noise -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
